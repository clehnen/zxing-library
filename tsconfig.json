{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "lib": [
      "es2020",
      "dom"
    ],
    "alwaysStrict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "useUnknownInCatchVariables": false,
    "sourceMap": true,
    "declaration": true,
    "preserveConstEnums": true,
    "paths": {
      "@zxing/library": [
        "./dist"
      ],
      "@zxing/library/*": [
        "./dist/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}